      "source": [
        "# ── STEP 7: Final Summary & Readiness Check ───────────────────\n",
        "from pathlib import Path\n",
        "import json\n",
        "\n",
        "TRAIN_PATH = Path(TRAIN_DIR)\n",
        "VALID_EXTS = ('.jpg', '.jpeg', '.png', '.webp')\n",
        "\n",
        "all_imgs = [p for p in TRAIN_PATH.iterdir() if p.suffix.lower() in VALID_EXTS]\n",
        "all_txts = [p for p in TRAIN_PATH.iterdir() if p.suffix == '.txt']\n",
        "paired   = sum(1 for img in all_imgs if (TRAIN_PATH / f'{img.stem}.txt').exists())\n",
        "\n",
        "print('\\n' + '='*60)\n",
        "print('  ✅ DATASET PREPARATION COMPLETE')\n",
        "print('='*60)\n",
        "print(f'  Total Images      : {len(all_imgs)}')\n",
        "print(f'  Paired (img+txt)  : {paired}')\n",
        "print(f'  Duplicates removed: {len(duplicates_removed)}')\n",
        "print(f'  Rejected (QC)     : {len(rejected)}')\n",
        "print(f'  Train Directory   : {TRAIN_DIR}')\n",
        "\n",
        "readiness = '🏆 ELITE' if len(all_imgs) >= 80 else ('✅ PROFESSIONAL' if len(all_imgs) >= 60 else ('⚠️  MINIMUM' if len(all_imgs) >= 30 else '❌ INSUFFICIENT'))\n",
        "print(f'\\n  Training Readiness: {readiness}')\n",
        "\n",
        "if len(all_imgs) < 30:\n",
        "    print(f'  ⚠️  Add {30 - len(all_imgs)} more images before training for minimum results.')\n",
        "\n",
        "print('\\n  Next Step: Open train_production_pipeline.ipynb and run!')\n",
        "print('='*60)"
      ]
    }
