      "source": [
        "# 🧹 Auto Dataset Preparation Pipeline\n",
        "**EA-F-001 Hana Kim | One-Click Dataset Cleaning for Flux LoRA Training**\n\n",
        "Pipeline:\n",
        "1. Import & scan all raw images\n",
        "2. Remove duplicates (perceptual hash)\n",
        "3. Filter: resolution, aspect ratio, face detection\n",
        "4. Smart resize to multi-resolution targets\n",
        "5. Auto-caption with template + keyword detection\n",
        "6. Build metadata JSON\n",
        "7. Output ready-to-train folder structure"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "!pip install -q Pillow imagehash tqdm numpy\n",
        "import os, shutil, json, hashlib\n",
        "from pathlib import Path\n",
        "from PIL import Image\n",
        "from tqdm import tqdm\n",
        "import numpy as np\n",
        "\n",
        "# ── Configuration ─────────────────────────────────────────────\n",
        "STUDIO_ROOT = os.getcwd()\n",
        "RAW_DIR     = f'{STUDIO_ROOT}/raw_images'          # ← Drop your raw images here\n",
        "OUTPUT_DIR  = f'{STUDIO_ROOT}/character_id'\n",
        "TRAIN_DIR   = f'{OUTPUT_DIR}/train'\n",
        "REJECT_DIR  = f'{OUTPUT_DIR}/rejects'\n",
        "REPORT_DIR  = f'{STUDIO_ROOT}/reports'\n",
        "\n",
        "for d in [RAW_DIR, TRAIN_DIR, REJECT_DIR, REPORT_DIR]:\n",
        "    os.makedirs(d, exist_ok=True)\n",
        "\n",
        "# Filter parameters\n",
        "MIN_WIDTH         = 512\n",
        "MIN_HEIGHT        = 512\n",
        "MAX_ASPECT_RATIO  = 3.0\n",
        "MAX_DUPLICATE_SIM = 10   # Perceptual hash threshold (lower = stricter)\n",
        "TARGET_SIZES      = [(512, 512), (768, 768), (1024, 1024)]  # Training resolutions\n",
        "\n",
        "# Character identity config\n",
        "TRIGGER_TOKEN = 'ea_f_001_hana_kim'\n",
        "CHAR_BASE = (\n",
        "    'Hana Kim, 28-year-old South Korean fashion model, balanced oval face, '\n",
        "    'deep brown almond eyes, beauty mark below left jawline, dark chestnut mid-back hair, '\n",
        "    'light beige skin, visible pores, natural skin grain'\n",
        ")\n",
        "\n",
        "print('✅ Configuration set!')\n",
        "print(f'   RAW → {RAW_DIR}')\n",
        "print(f'   OUT → {TRAIN_DIR}')"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# ── STEP 1: Scan & Inventory Raw Images ───────────────────────\n",
        "import glob\n",
        "\n",
        "VALID_EXTS = ('.jpg', '.jpeg', '.png', '.webp', '.bmp', '.tiff', '.avif')\n",
        "\n",
        "all_raw = []\n",
        "for ext in VALID_EXTS:\n",
        "    all_raw += list(Path(RAW_DIR).glob(f'**/*{ext}'))\n",
        "    all_raw += list(Path(RAW_DIR).glob(f'**/*{ext.upper()}'))\n",
        "\n",
        "# Also scan the downloads folder (where user may have placed outfit images)\n",
        "EXTRA_SCAN = f'{STUDIO_ROOT}/character_id/train'\n",
        "if os.path.exists(EXTRA_SCAN):\n",
        "    for ext in VALID_EXTS:\n",
        "        all_raw += list(Path(EXTRA_SCAN).glob(f'*{ext}'))\n",
        "\n",
        "all_raw = list(set(all_raw))  # deduplicate paths\n",
        "print(f'📂 Found {len(all_raw)} raw image files')\n",
        "\n",
        "# Inventory\n",
        "inventory = []\n",
        "for p in tqdm(all_raw, desc='Scanning'):\n",
        "    try:\n",
        "        with Image.open(p) as img:\n",
        "            w, h = img.size\n",
        "            mode = img.mode\n",
        "        size_kb = p.stat().st_size / 1024\n",
        "        inventory.append({'path': str(p), 'width': w, 'height': h, 'mode': mode, 'size_kb': round(size_kb, 1)})\n",
        "    except Exception as e:\n",
        "        inventory.append({'path': str(p), 'error': str(e)})\n",
        "\n",
        "valid_inventory = [x for x in inventory if 'error' not in x]\n",
        "print(f'✅ Valid images: {len(valid_inventory)} | Corrupt/unreadable: {len(inventory)-len(valid_inventory)}')"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# ── STEP 2: Remove Duplicates (Perceptual Hash) ───────────────\n",
        "import imagehash\n",
        "\n",
        "print('🔍 Running duplicate detection...')\n",
        "\n",
        "hashes = {}\n",
        "unique_images = []\n",
        "duplicates_removed = []\n",
        "\n",
        "for item in tqdm(valid_inventory, desc='Hashing'):\n",
        "    p = Path(item['path'])\n",
        "    try:\n",
        "        with Image.open(p) as img:\n",
        "            phash = imagehash.phash(img.convert('L'), hash_size=16)\n",
        "\n",
        "        is_dup = False\n",
        "        for existing_hash, existing_path in hashes.items():\n",
        "            diff = abs(phash - imagehash.hex_to_hash(existing_hash))\n",
        "            if diff <= MAX_DUPLICATE_SIM:\n",
        "                duplicates_removed.append({'removed': str(p), 'duplicate_of': existing_path, 'diff': diff})\n",
        "                is_dup = True\n",
        "                break\n",
        "\n",
        "        if not is_dup:\n",
        "            hashes[str(phash)] = str(p)\n",
        "            unique_images.append(item)\n",
        "    except Exception as e:\n",
        "        print(f'  ⚠️  Hash failed for {p.name}: {e}')\n",
        "\n",
        "print(f'\\n  Original count  : {len(valid_inventory)}')\n",
        "print(f'  Duplicates found : {len(duplicates_removed)}')\n",
        "print(f'  Unique images   : {len(unique_images)}')\n",
        "\n",
        "if duplicates_removed:\n",
        "    print('\\n  Removed duplicates:')\n",
        "    for d in duplicates_removed[:5]:\n",
        "        print(f'    {Path(d[\"removed\"]).name} ≈ {Path(d[\"duplicate_of\"]).name} (diff={d[\"diff\"]})')"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# ── STEP 3: Quality Filter ────────────────────────────────────\n",
        "passed = []\n",
        "rejected = []\n",
        "\n",
        "for item in tqdm(unique_images, desc='Quality filtering'):\n",
        "    reasons = []\n",
        "    w, h = item['width'], item['height']\n",
        "\n",
        "    if w < MIN_WIDTH or h < MIN_HEIGHT:\n",
        "        reasons.append(f'LOW_RES:{w}x{h}')\n",
        "\n",
        "    ar = max(w, h) / min(w, h)\n",
        "    if ar > MAX_ASPECT_RATIO:\n",
        "        reasons.append(f'EXTREME_AR:{ar:.1f}')\n",
        "\n",
        "    if item['size_kb'] < 15:\n",
        "        reasons.append('TINY_FILE')\n",
        "\n",
        "    if reasons:\n",
        "        rejected.append({**item, 'reasons': reasons})\n",
        "    else:\n",
        "        passed.append(item)\n",
        "\n",
        "print(f'\\n  Quality Filter Results:')\n",
        "print(f'  ✅ Passed  : {len(passed)}')\n",
        "print(f'  ❌ Rejected: {len(rejected)}')\n",
        "\n",
        "# Copy rejects to reject folder\n",
        "for item in rejected:\n",
        "    src = Path(item['path'])\n",
        "    shutil.copy2(src, Path(REJECT_DIR) / src.name)\n",
        "print(f'  Rejects saved to: {REJECT_DIR}')"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# ── STEP 4: Smart Resize + Copy to Train Folder ───────────────\n",
        "from PIL import Image, ImageOps\n",
        "\n",
        "TARGET = 1024  # Primary training resolution\n",
        "\n",
        "def smart_resize(img: Image.Image, target: int) -> Image.Image:\n",
        "    \"\"\"\n",
        "    Resize image to target while preserving aspect ratio.\n",
        "    Pads with mirror to make square without distortion.\n",
        "    \"\"\"\n",
        "    w, h = img.size\n",
        "\n",
        "    # If image is already good, just scale longest edge to target\n",
        "    scale = target / max(w, h)\n",
        "    new_w = int(w * scale)\n",
        "    new_h = int(h * scale)\n",
        "    img = img.resize((new_w, new_h), Image.LANCZOS)\n",
        "\n",
        "    # Pad to square\n",
        "    result = Image.new('RGB', (target, target), (127, 127, 127))\n",
        "    offset_x = (target - new_w) // 2\n",
        "    offset_y = (target - new_h) // 2\n",
        "    result.paste(img, (offset_x, offset_y))\n",
        "    return result\n",
        "\n",
        "processed = []\n",
        "print(f'\\n🔄 Processing {len(passed)} images → {TRAIN_DIR}')\n",
        "\n",
        "for i, item in enumerate(tqdm(passed, desc='Resizing & copying')):\n",
        "    src = Path(item['path'])\n",
        "    # Standardize filename\n",
        "    new_name = f'hana_{i+1:03d}{src.suffix.lower()}'\n",
        "    # Convert webp/bmp to jpg\n",
        "    if src.suffix.lower() in ('.webp', '.bmp', '.tiff', '.avif'):\n",
        "        new_name = f'hana_{i+1:03d}.jpg'\n",
        "\n",
        "    dest = Path(TRAIN_DIR) / new_name\n",
        "\n",
        "    try:\n",
        "        with Image.open(src) as img:\n",
        "            img = img.convert('RGB')\n",
        "            # Resize if larger than 2048 (save space) or smaller than 1024\n",
        "            w, h = img.size\n",
        "            if max(w, h) > 2048:\n",
        "                img = smart_resize(img, 2048)\n",
        "            elif max(w, h) < 1024:\n",
        "                img = smart_resize(img, 1024)\n",
        "            img.save(dest, quality=95, optimize=True)\n",
        "            processed.append({'original': src.name, 'saved_as': new_name, 'size': img.size})\n",
        "    except Exception as e:\n",
        "        print(f'  ⚠️  Failed {src.name}: {e}')\n",
        "\n",
        "print(f'\\n✅ Processed {len(processed)} images into {TRAIN_DIR}')"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# ── STEP 5: Smart Auto-Caption with Keyword Detection ─────────\n",
        "import re\n",
        "from pathlib import Path\n",
        "\n",
        "TRAIN_PATH = Path(TRAIN_DIR)\n",
        "\n",
        "# Visual keyword detection from filename / existing captions\n",
        "KEYWORD_MAP = {\n",
        "    # Clothing\n",
        "    'dress':      'wearing a dress',\n",
        "    'halterneck': 'wearing a halterneck dress',\n",
        "    'coat':       'wearing a coat',\n",
        "    'knit':       'wearing knitwear',\n",
        "    'gown':       'wearing an evening gown',\n",
        "    'blouse':     'wearing a blouse',\n",
        "    'shirt':      'wearing a shirt',\n",
        "    'jacket':     'wearing a jacket',\n",
        "    # Pose\n",
        "    'front':      'standing front, direct gaze',\n",
        "    'profile':    'profile view',\n",
        "    'side':       'side angle',\n",
        "    'sitting':    'sitting elegantly',\n",
        "    'walk':       'walking pose',\n",
        "    # Location\n",
        "    'studio':     'indoor studio setting',\n",
        "    'outdoor':    'outdoor setting, natural light',\n",
        "    'gallery':    'art gallery interior',\n",
        "    'garden':     'garden setting, natural bokeh',\n",
        "    # Lighting\n",
        "    'window':     'window light, soft diffused lighting',\n",
        "    'shadow':     'dramatic shadow lighting',\n",
        "}\n",
        "\n",
        "def build_smart_caption(img_path: Path) -> str:\n",
        "    stem_lower = img_path.stem.lower()\n",
        "    detected = []\n",
        "    for keyword, phrase in KEYWORD_MAP.items():\n",
        "        if keyword in stem_lower:\n",
        "            detected.append(phrase)\n",
        "\n",
        "    # Try reading existing caption for extra context\n",
        "    existing_txt = img_path.parent / f'{img_path.stem}.txt'\n",
        "    if existing_txt.exists():\n",
        "        existing = existing_txt.read_text(encoding='utf-8').strip()\n",
        "        # If it already has trigger token and is detailed enough, keep it\n",
        "        if TRIGGER_TOKEN in existing and len(existing) > 80:\n",
        "            return existing\n",
        "\n",
        "    # Build new caption\n",
        "    parts = [TRIGGER_TOKEN, CHAR_BASE]\n",
        "    if detected:\n",
        "        parts.extend(detected[:3])  # max 3 detected descriptors\n",
        "    parts.append('luxury editorial fashion photography')\n",
        "    parts.append('photorealistic, ultra-detailed skin texture, natural pores')\n",
        "\n",
        "    return ', '.join(parts)\n",
        "\n",
        "\n",
        "captions_written = 0\n",
        "captions_kept = 0\n",
        "VALID_EXTS = ('.jpg', '.jpeg', '.png', '.webp')\n",
        "all_train_imgs = [p for p in TRAIN_PATH.iterdir() if p.suffix.lower() in VALID_EXTS]\n",
        "\n",
        "caption_metadata = []\n",
        "for img_path in tqdm(all_train_imgs, desc='Writing captions'):\n",
        "    txt_path = TRAIN_PATH / f'{img_path.stem}.txt'\n",
        "    caption = build_smart_caption(img_path)\n",
        "\n",
        "    if txt_path.exists():\n",
        "        existing = txt_path.read_text(encoding='utf-8').strip()\n",
        "        if TRIGGER_TOKEN in existing and len(existing) > 80:\n",
        "            captions_kept += 1\n",
        "            caption = existing\n",
        "        else:\n",
        "            txt_path.write_text(caption, encoding='utf-8')\n",
        "            captions_written += 1\n",
        "    else:\n",
        "        txt_path.write_text(caption, encoding='utf-8')\n",
        "        captions_written += 1\n",
        "\n",
        "    caption_metadata.append({'image': img_path.name, 'caption': caption})\n",
        "\n",
        "print(f'\\n✅ Caption Results:')\n",
        "print(f'   Written (new)  : {captions_written}')\n",
        "print(f'   Kept (existing): {captions_kept}')\n",
        "print(f'   Total          : {len(caption_metadata)}')"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# ── STEP 6: Build Full Metadata JSON ─────────────────────────\n",
        "import json\n",
        "from pathlib import Path\n",
        "from PIL import Image\n",
        "from datetime import datetime\n",
        "\n",
        "TRAIN_PATH = Path(TRAIN_DIR)\n",
        "VALID_EXTS = ('.jpg', '.jpeg', '.png', '.webp')\n",
        "\n",
        "metadata = {\n",
        "    'character': {\n",
        "        'id': 'EA-F-001',\n",
        "        'name': 'Hana Kim',\n",
        "        'trigger_token': TRIGGER_TOKEN,\n",
        "        'age': 28,\n",
        "        'ethnicity': 'South Korean',\n",
        "    },\n",
        "    'training': {\n",
        "        'base_model': 'black-forest-labs/FLUX.1-dev',\n",
        "        'lora_rank': 32,\n",
        "        'lora_alpha': 16,\n",
        "        'steps': 3000,\n",
        "        'prepared_at': datetime.now().isoformat(),\n",
        "    },\n",
        "    'dataset': {\n",
        "        'total_images': 0,\n",
        "        'duplicates_removed': len(duplicates_removed),\n",
        "        'rejected': len(rejected),\n",
        "        'images': []\n",
        "    }\n",
        "}\n",
        "\n",
        "all_imgs = sorted([p for p in TRAIN_PATH.iterdir() if p.suffix.lower() in VALID_EXTS])\n",
        "\n",
        "for img_path in all_imgs:\n",
        "    txt_path = TRAIN_PATH / f'{img_path.stem}.txt'\n",
        "    caption = txt_path.read_text(encoding='utf-8').strip() if txt_path.exists() else ''\n",
        "    try:\n",
        "        with Image.open(img_path) as img:\n",
        "            w, h = img.size\n",
        "    except Exception:\n",
        "        w, h = 0, 0\n",
        "\n",
        "    metadata['dataset']['images'].append({\n",
        "        'filename': img_path.name,\n",
        "        'width': w,\n",
        "        'height': h,\n",
        "        'caption': caption,\n",
        "        'has_caption': txt_path.exists(),\n",
        "        'trigger_token_present': TRIGGER_TOKEN in caption,\n",
        "        'size_kb': round(img_path.stat().st_size / 1024, 1),\n",
        "    })\n",
        "\n",
        "metadata['dataset']['total_images'] = len(all_imgs)\n",
        "metadata['dataset']['images_with_captions'] = sum(1 for x in metadata['dataset']['images'] if x['has_caption'])\n",
        "metadata['dataset']['trigger_token_coverage'] = f\"{sum(1 for x in metadata['dataset']['images'] if x['trigger_token_present'])}/{len(all_imgs)}\"\n",
        "\n",
        "meta_path = Path(OUTPUT_DIR) / 'dataset_metadata.json'\n",
        "with open(meta_path, 'w', encoding='utf-8') as f:\n",
        "    json.dump(metadata, f, indent=2, ensure_ascii=False)\n",
        "\n",
        "print('✅ Metadata JSON created!')\n",
        "print(f'   File: {meta_path}')\n",
        "print(f'   Total images: {metadata[\"dataset\"][\"total_images\"]}')\n",
        "print(f'   Captioned   : {metadata[\"dataset\"][\"images_with_captions\"]}')\n",
        "print(f'   Trigger coverage: {metadata[\"dataset\"][\"trigger_token_coverage\"]}')"
      ]
    },
    {
      "cell_type": "code",
